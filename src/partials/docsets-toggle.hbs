<button id="docsets-toggle" class="navbar-item docsets-toggle docs" type="button" aria-label="Browse docsets" aria-haspopup="dialog">
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="4" width="4" height="16" rx="1"/>
    <rect x="10" y="4" width="4" height="16" rx="1"/>
    <rect x="16" y="4" width="4" height="16" rx="1"/>
  </svg>
</button>
<dialog id="docsets-modal" class="docsets-modal" aria-labelledby="docsets-modal-title">
  <header class="docsets-modal__header">
    <h2 id="docsets-modal-title">Browse docs</h2>
    <button id="docsets-modal-close" class="docsets-modal__close" type="button" aria-label="Close">&times;</button>
  </header>
  <div id="docsets-modal-root" class="docsets-modal__body"></div>
</dialog>
